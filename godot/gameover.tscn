[sub_resource type="GDScript" id="2"]
script/source = "extends Control

signal focus

func _ready():
	for option in get_children():
		if option is Button:
			option.connect(\"focus_entered\", Callable(self, \"_on_focus\").bind(option))

func _on_focus(node: Control):
	emit_signal(\"focus\", node)"

